<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Mahtab GPT - AI Agent with Memory</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif;
            background: linear-gradient(135deg, #2905aa 0%, #1a0475 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* Chat container - your original rounded border with different color */
        .chat-container {
            max-width: 700px;
            width: 100%;
            background: rgb(180, 15, 131);
            border-radius: 48px;
            box-shadow: 0 20px 35px rgba(0, 0, 0, 0.4), 0 0 0 4px #e64b4b, 0 0 0 8px #f703ad;
            overflow: hidden;
            transition: all 0.2s ease;
        }

        /* Header with gradient */
        .chat-header {
            background: linear-gradient(95deg, #f703ad, #e64b4b);
            padding: 20px 25px;
            text-align: center;
            border-bottom: 3px solid #08c6f5;
        }

        .chat-header h2 {
            margin: 0;
            font-size: 1.8rem;
            letter-spacing: 1px;
            background: linear-gradient(135deg, #fff, #ffe6f0);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .chat-header p {
            color: #fff9e0;
            margin-top: 6px;
            font-size: 0.85rem;
            font-weight: bold;
            text-shadow: 1px 1px 0 #690707;
        }

        /* Chat messages area */
        .chat-messages {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(2px);
            height: 400px;
            overflow-y: auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            scroll-behavior: smooth;
        }

        /* Custom scrollbar */
        .chat-messages::-webkit-scrollbar {
            width: 8px;
        }
        .chat-messages::-webkit-scrollbar-track {
            background: #690707;
            border-radius: 10px;
        }
        .chat-messages::-webkit-scrollbar-thumb {
            background: #08c6f5;
            border-radius: 10px;
        }

        /* Message bubbles */
        .message {
            max-width: 80%;
            padding: 10px 16px;
            border-radius: 24px;
            line-height: 1.4;
            word-wrap: break-word;
            font-size: 1rem;
            animation: fadeIn 0.2s ease;
        }

        .user-message {
            align-self: flex-end;
            background: #f52a06;
            color: white;
            border-bottom-right-radius: 6px;
            box-shadow: -3px 3px 0 rgba(0,0,0,0.1);
        }

        .bot-message {
            align-self: flex-start;
            background: #690707;
            color: #f0f0f0;
            border-bottom-left-radius: 6px;
            box-shadow: 3px 3px 0 rgba(0,0,0,0.1);
            border: 1px solid #08c6f5;
        }

        /* Input area */
        .input-area {
            display: flex;
            padding: 18px 20px;
            background: #2905aa;
            gap: 12px;
            border-top: 2px solid #08c6f5;
        }

        .input-area input {
            flex: 1;
            background: #f4f0ff;
            border: 2px solid #08c6f5;
            border-radius: 60px;
            padding: 14px 20px;
            font-size: 1rem;
            outline: none;
            font-family: inherit;
            transition: 0.2s;
            color: #1a0475;
            font-weight: bold;
        }

        .input-area input:focus {
            border-color: #f703ad;
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(247, 3, 173, 0.3);
        }

        .input-area button {
            background: #f703ad;
            border: none;
            border-radius: 60px;
            padding: 0 28px;
            font-size: 1.1rem;
            font-weight: bold;
            color: white;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            font-family: inherit;
        }

        .input-area button:hover {
            background: #e64b4b;
            transform: scale(0.97);
            cursor: pointer;
        }

        .status {
            text-align: center;
            font-size: 0.7rem;
            padding: 8px;
            background: #1a0475;
            color: #bbb;
            border-top: 1px solid #08c6f5;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px);}
            to { opacity: 1; transform: translateY(0);}
        }

        /* responsive */
        @media (max-width: 550px) {
            .chat-container {
                border-radius: 32px;
            }
            .message {
                max-width: 90%;
                font-size: 0.9rem;
            }
            .input-area button {
                padding: 0 20px;
            }
        }
    </style>
</head>
<body>
<div class="chat-container">
    <div class="chat-header">
        <h2>🤖 MAHTAB GPT</h2>
        <p>⚡ AI Agent with Memory | Powered by n8n + Your Backend</p>
    </div>

    <div id="chatMessages" class="chat-messages">
        <!-- messages will appear here -->
        <div class="message bot-message">✨ Hello! I'm your AI agent. I remember what you tell me. Try: "My name is Mahtab"</div>
    </div>

    <div class="input-area">
        <input type="text" id="userInput" placeholder="Ask me anything..." autocomplete="off">
        <button id="sendBtn">➤ SEND</button>
    </div>
    <div class="status">
        <span id="statusText">🟢 Ready</span> &nbsp;|&nbsp; Session ID: <span id="sessionDisplay">---</span>
    </div>
</div>

<script>
    // Generate a unique session ID for this browser session (memory persistence)
    let sessionId = localStorage.getItem('mahtab_session_id');
    if (!sessionId) {
        sessionId = Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 5);
        localStorage.setItem('mahtab_session_id', sessionId);
    }
    document.getElementById('sessionDisplay').innerText = sessionId.slice(-8);

    const chatDiv = document.getElementById('chatMessages');
    const userInput = document.getElementById('userInput');
    const sendBtn = document.getElementById('sendBtn');
    const statusSpan = document.getElementById('statusText');

    // Function to add message to chat
    function addMessage(text, sender) {
        const messageDiv = document.createElement('div');
        messageDiv.classList.add('message');
        messageDiv.classList.add(sender === 'user' ? 'user-message' : 'bot-message');
        messageDiv.innerText = text;
        chatDiv.appendChild(messageDiv);
        // Auto-scroll to bottom
        chatDiv.scrollTop = chatDiv.scrollHeight;
    }

    // Function to send message to backend
    async function sendMessageToBackend(message) {
        statusSpan.innerHTML = '⏳ Sending...';
        statusSpan.style.color = '#f703ad';
        try {
            const response = await fetch('http://localhost:3000/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: message, sessionId: sessionId })
            });
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }
            const data = await response.json();
            // data should have a "reply" field
            const reply = data.reply || "Sorry, I didn't understand that.";
            addMessage(reply, 'bot');
            statusSpan.innerHTML = '✅ Connected';
            statusSpan.style.color = '#0f0';
        } catch (error) {
            console.error('Frontend error:', error);
            addMessage(`⚠️ Backend error: ${error.message}. Make sure server is running (node server.js) and n8n test listener is active.`, 'bot');
            statusSpan.innerHTML = '❌ Backend offline';
            statusSpan.style.color = '#f52a06';
        }
    }

    // Handle sending
    async function handleSend() {
        const text = userInput.value.trim();
        if (text === "") return;

        // Add user message to UI immediately
        addMessage(text, 'user');
        userInput.value = '';
        userInput.focus();

        await sendMessageToBackend(text);
    }

    // Event listeners
    sendBtn.addEventListener('click', handleSend);
    userInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            handleSend();
        }
    });

    // initial status: check if backend is reachable quickly (optional ping, but not required)
    async function pingBackend() {
        try {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), 2000);
            await fetch('http://localhost:3000/chat', {
                method: 'OPTIONS',
                signal: controller.signal
            }).catch(() => {});
            clearTimeout(timeoutId);
            statusSpan.innerHTML = '🟢 Backend online';
            statusSpan.style.color = '#90ff90';
        } catch (e) {
            statusSpan.innerHTML = '⚠️ Backend not reachable (start node server.js)';
            statusSpan.style.color = '#f52a06';
        }
    }
    // optional ping (not critical for functionality)
    setTimeout(pingBackend, 500);
</script>
</body>
</html>    
const express = require('express');
const cors = require('cors');
const app = express();
app.use(cors());
app.use(express.json());

const memory = {};

app.post('/chat', (req, res) => {
  const { message, sessionId } = req.body;
  if (!memory[sessionId]) memory[sessionId] = {};
  let reply = '';
  const cleanMsg = message.toLowerCase().replace(/[^\w\s]/g, '');
  if (cleanMsg.includes('my name is')) {
    const name = message.split(/my name is/i)[1]?.trim();
    if (name) {
      memory[sessionId].name = name;
      reply = `Nice to meet you, ${name}! I'll remember your name.`;
    } else reply = "Tell me your name like 'My name is Mahtab'.";
  } else if (cleanMsg.includes('what is my name')) {
    const name = memory[sessionId].name;
    reply = name ? `Your name is ${name}.` : "You haven't told me your name yet.";
  } else {
    reply = `You said: "${message}". I'm a mock AI. Tell me your name.`;
  }
  res.json({ reply });
});

app.listen(3000, () => console.log('✅ Mock server running at http://localhost:3000'));
